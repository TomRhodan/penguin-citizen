{
  "productName": "Penguin Citizen",
  "version": "0.4.7",
  "identifier": "com.penguincitizen.launcher",
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "resources": ["resources/penguin-citizen-helper.exe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Game",
    "shortDescription": "A Linux management tool for Star Citizen"
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Penguin Citizen",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 700,
        "decorations": false,
        "center": true
      }
    ]
  }
}
